NODE_ENV=development
PORT=3004

# RabbitMQ
RABBITMQ_URL=amqp://app:secret@localhost:5672
RABBITMQ_EXCHANGE=ecommerce.events
RABBITMQ_QUEUE=notification-service.queue
RABBITMQ_RECONNECT_DELAY_MS=5000

# SMTP — use Mailtrap for local dev (https://mailtrap.io)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_NAME=EcommerceApp
SMTP_FROM_EMAIL=noreply@ecommerceapp.com

# Frontend base URL — used in email links
FRONTEND_URL=http://localhost:3000
